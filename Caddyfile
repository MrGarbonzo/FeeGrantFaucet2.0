# Caddy reverse proxy for the fee-grant faucet.
#
# SecretVM assigns a RANDOM <name>.vm.scrtlabs.com hostname at deploy time, so the
# domain is unknown when we build/deploy. On-demand TLS makes Caddy obtain a cert
# for whatever hostname is presented during the TLS handshake — no DOMAIN needed.
{
    on_demand_tls {
        # Liveness gate: only attempt issuance if the faucet answers 200. Limits
        # abuse of on-demand issuance. For stricter protection, point this at a
        # faucet endpoint that validates the ?domain= suffix (e.g. *.vm.scrtlabs.com).
        ask http://faucet:3001/
    }
}

:443 {
    tls {
        on_demand
    }
    reverse_proxy faucet:3001
}

# Redirect plain HTTP to HTTPS. (ACME challenges are handled by Caddy internally
# and take precedence over this redirect.)
:80 {
    redir https://{host}{uri}
}
